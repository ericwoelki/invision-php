{
    "name": "ericwoelki/invision-php",
    "description": "PHP api client for Invision Community.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Eric Woelki",
            "email": "ericwoelki@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3.0",
        "nesbot/carbon": "^3.11.4",
        "saloonphp/pagination-plugin": "^2.3",
        "saloonphp/saloon": "^4.0"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "pestphp/pest": "^4.6.1",
        "phpstan/phpstan": "^2.1.49",
        "rector/rector": "^2.4.2",
        "symfony/var-dumper": "^7.4.8"
    },
    "autoload": {
        "psr-4": {
            "EricWoelki\\Invision\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "analyze": "phpstan analyze",
        "refactor": "rector",
        "lint": "pint",
        "test:refactor": "rector --dry-run",
        "test:lint": "pint --test",
        "test:analyze": "phpstan analyze",
        "test:unit": "pest --parallel",
        "test": [
            "@test:refactor",
            "@test:lint",
            "@test:analyze",
            "@test:unit"
        ]
    }
}
